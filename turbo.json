{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**", ".strapi/**", ".next/**"]
    },
    "generate:types": {
      "outputs": ["apps/cms/src/payload-types.ts"]
    }
  }
}