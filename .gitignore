# =============================================================================
# Magnetic Cosmetics — TanStack Start + Strapi Monorepo
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment Variables ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Keep example files so developers know what vars are needed
!.env.example
!apps/**/.env.example

# ── Build Outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/

# TanStack Start / Vite / Vinxi
.output/
.vinxi/
.nitro/
.vercel/

# ── Strapi (apps/cms) ─────────────────────────────────────────────────────────
apps/cms/.strapi/
apps/cms/.tmp/
apps/cms/build/
apps/cms/dist/

# Strapi exports / imports
apps/cms/exports/
apps/cms/imports/

# Strapi SQLite database (dev only — use Postgres in production)
apps/cms/*.db
apps/cms/*.db-journal

# Strapi uploads (media files managed locally)
apps/cms/public/uploads/

# ── TanStack Start (apps/shop) ────────────────────────────────────────────────
apps/shop/.output/
apps/shop/.vinxi/
apps/shop/.nitro/

# ── Turborepo ─────────────────────────────────────────────────────────────────
.turbo/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

